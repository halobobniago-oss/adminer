<script>
    function showModal(id) { document.getElementById(id).style.display = 'flex'; }
    function setRename(name) { document.getElementById('renameOld').value = name; showModal('renameModal'); }
    function setChmod(name) { document.getElementById('chmodTarget').value = name; showModal('chmodModal'); }
    
    function toggleAll(cb) { document.querySelectorAll('.file-check').forEach(c => c.checked = cb.checked); }
    
    function executeSelected() {
        let s = Array.from(document.querySelectorAll('.file-check:checked')).map(c => c.value);
        if (s.length === 0) { alert('Select files/folders first'); return; }
        if (confirm('Delete ' + s.length + ' item(s)?')) {
            document.getElementById('delSelectedInput').value = '1';
            document.getElementById('fileForm').submit();
        }
    }
    
    window.onclick = function(e) {
        if (e.target.classList && e.target.classList.contains('modal')) e.target.style.display = 'none';
    }
</script>
