function format_size($b) {
    if (!$b || $b <= 0) return '0 B';
    $u = ['B', 'KB', 'MB', 'GB', 'TB'];
    $i = 0;
    while ($b >= 1024 && $i < 4) { $b /= 1024; $i++; }
    return round($b, 2) . ' ' . $u[$i];
}

